---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import '../../styles/global.css';

const allWorks = await getCollection('works');

// Individual works: non-group, non-residency, sorted by year desc then order asc
const works = allWorks
  .filter(w => !w.data.isResidency && !w.data.isGroupWork)
  .sort((a, b) => (b.data.year ?? 0) - (a.data.year ?? 0) || a.data.order - b.data.order);

// Group works: sorted by year desc
const groupWorks = allWorks
  .filter(w => w.data.isGroupWork)
  .sort((a, b) => (b.data.year ?? 0) - (a.data.year ?? 0));
---

<Layout title="Works">
  <div class="page-header">
    <h1>Works / 作品</h1>
  </div>

  <div class="works-grid">
    {works.map(work => {
      const cover = work.data.coverImage || work.data.images[0];
      return (
        <a href={`/works/${work.slug}`} class="work-card">
          <div class="work-card__image-wrap">
            {cover ? (
              <img src={`/images/${cover}`} alt={work.data.titleEn} loading="lazy" />
            ) : (
              <div class="work-card__no-image">No image</div>
            )}
          </div>
          <div class="work-card__meta">
            <p class="work-card__title-en">{work.data.titleEn}</p>
            <p class="work-card__title-zh">{work.data.titleZh}</p>
            <p class="work-card__year">
              {work.data.yearDisplay || work.data.year}
              {work.data.mediumEn && <> &nbsp;·&nbsp; {work.data.mediumEn}</>}
            </p>
          </div>
        </a>
      );
    })}
  </div>

  {groupWorks.length > 0 && (
    <>
      <p class="home-section-label" style="margin-top: 2rem;">團體作品 / Group Works</p>
      <div class="works-grid">
        {groupWorks.map(work => {
          const cover = work.data.coverImage || work.data.images[0];
          return (
            <a href={`/works/${work.slug}`} class="work-card">
              <div class="work-card__image-wrap">
                {cover ? (
                  <img src={`/images/${cover}`} alt={work.data.titleEn} loading="lazy" />
                ) : (
                  <div class="work-card__no-image">No image</div>
                )}
              </div>
              <div class="work-card__meta">
                <p class="work-card__title-en">{work.data.titleEn}</p>
                <p class="work-card__title-zh">{work.data.titleZh}</p>
                <p class="work-card__year">
                  {work.data.yearDisplay || work.data.year}
                </p>
              </div>
            </a>
          );
        })}
      </div>
    </>
  )}
</Layout>
